---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { getReadingTime } from "../../utils";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { title, description, pubDate, categories } = post.data;
const { Content, headings } = await render(post);

// Calculate reading time
const readingTime = getReadingTime(post.body);

// Filter headings for TOC (H2 and H3 only)
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);

// Format date in French
const formattedDate = new Date(pubDate).toLocaleDateString("fr-FR", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Layout title={`${title} | Blog de Ludovic Coullet`} description={description}>
  <main id="main-content" class="flex-grow container mx-auto px-6 py-12 md:py-20 focus:outline-none" tabindex="-1">
    <!-- Main layout: grid on desktop, single column on mobile -->
    <div class="max-w-6xl mx-auto lg:grid lg:grid-cols-[1fr_260px] lg:gap-12 items-start">
      
      <!-- Left Column: Article content -->
      <article class="max-w-2xl mx-auto lg:mx-0 w-full">
        <!-- Back button -->
        <a
          href="/blog"
          class="inline-flex items-center gap-1.5 text-sm font-semibold text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors mb-8 group focus-ring-custom rounded-lg"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
          </svg>
          Retour aux articles
        </a>

        <!-- Article Header -->
        <header class="mb-8 pb-8 border-b border-zinc-200 dark:border-zinc-800">
          <div class="flex flex-wrap items-center gap-2 sm:gap-3 text-sm text-zinc-500 dark:text-zinc-400 mb-4">
            <time datetime={pubDate.toISOString()} class="font-medium">
              {formattedDate}
            </time>
            <span class="text-zinc-300 dark:text-zinc-700" aria-hidden="true">•</span>
            <span class="font-medium">{readingTime} min de lecture</span>
            {categories.length > 0 && (
              <>
                <span class="text-zinc-300 dark:text-zinc-700" aria-hidden="true">•</span>
                <div class="flex flex-wrap gap-1.5" aria-label="Catégories">
                  {categories.map((category) => (
                    <a
                      href={`/blog/category/${encodeURIComponent(category)}`}
                      class="px-2.5 py-0.5 rounded-full bg-zinc-100 dark:bg-zinc-800 hover:bg-zinc-200 dark:hover:bg-zinc-700 text-zinc-700 dark:text-zinc-300 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors text-xs font-semibold focus-ring-custom"
                    >
                      {category}
                    </a>
                  ))}
                </div>
              </>
            )}
          </div>
          <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight text-zinc-950 dark:text-zinc-50 leading-tight">
            {title}
          </h1>
          {description && (
            <p class="mt-4 text-lg text-zinc-600 dark:text-zinc-400 leading-relaxed font-normal">
              {description}
            </p>
          )}
        </header>

        <!-- Mobile TOC: displayed only on screens < lg (large) -->
        {tocHeadings.length > 0 && (
          <div class="lg:hidden mb-8 border border-zinc-200 dark:border-zinc-800 rounded-xl overflow-hidden bg-white dark:bg-zinc-900 transition-all duration-300">
            <details class="group">
              <summary class="flex items-center justify-between p-4 font-bold text-sm text-zinc-950 dark:text-zinc-50 cursor-pointer list-none select-none focus:outline-none focus:bg-zinc-50 dark:focus:bg-zinc-800/50">
                <span>Table des matières</span>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 text-zinc-500 group-open:rotate-180 transition-transform">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                </svg>
              </summary>
              <nav class="border-t border-zinc-100 dark:border-zinc-800 p-4 bg-zinc-50/50 dark:bg-zinc-900/50" aria-label="Table des matières (Mobile)">
                <ul class="space-y-2.5 text-sm">
                  {tocHeadings.map((heading) => (
                    <li style={{ paddingLeft: `${(heading.depth - 2) * 1}rem` }}>
                      <a
                        href={`#${heading.slug}`}
                        class="text-zinc-600 dark:text-zinc-400 hover:text-zinc-950 dark:hover:text-zinc-50 hover:underline transition-colors block leading-relaxed focus-ring-custom rounded"
                      >
                        {heading.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            </details>
          </div>
        )}

        <!-- Main rich-text content rendered with Tailwind Typography -->
        <div class="prose prose-zinc prose-lg max-w-none dark:prose-invert focus:outline-none 
                    prose-headings:font-bold prose-headings:tracking-tight prose-headings:text-zinc-950 dark:prose-headings:text-zinc-50
                    prose-p:leading-relaxed prose-p:text-zinc-700 dark:prose-p:text-zinc-300
                    prose-a:text-zinc-900 dark:prose-a:text-zinc-100 prose-a:underline prose-a:underline-offset-4 hover:prose-a:text-zinc-600 dark:hover:prose-a:text-zinc-400 prose-a:transition-colors
                    prose-blockquote:border-l-4 prose-blockquote:border-zinc-300 dark:prose-blockquote:border-zinc-700 prose-blockquote:pl-4 prose-blockquote:italic prose-blockquote:text-zinc-600 dark:prose-blockquote:text-zinc-400
                    prose-code:text-zinc-900 dark:prose-code:text-zinc-100 prose-code:bg-zinc-100 dark:prose-code:bg-zinc-800 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm prose-code:font-mono
                    prose-pre:bg-zinc-900 dark:prose-pre:bg-zinc-900/80 prose-pre:text-zinc-100 prose-pre:p-4 prose-pre:rounded-xl prose-pre:overflow-x-auto
                    prose-ul:list-disc prose-ul:pl-5
                    prose-ol:list-decimal prose-ol:pl-5">
          <Content />
        </div>
      </article>
      
      <!-- Right Column: Sticky Sidebar TOC (displayed only on lg screens) -->
      {tocHeadings.length > 0 && (
        <aside class="hidden lg:block sticky top-24 w-full pr-4 max-h-[calc(100vh-8rem)] overflow-y-auto" aria-label="Table des matières (Bureau)">
          <div class="border-l border-zinc-200 dark:border-zinc-800 pl-4 py-1">
            <h2 class="text-xs font-bold uppercase tracking-wider text-zinc-400 dark:text-zinc-500 mb-4 select-none">
              Dans cet article
            </h2>
            <nav>
              <ul class="space-y-3.5 text-[13px]">
                {tocHeadings.map((heading) => (
                  <li style={{ paddingLeft: `${(heading.depth - 2) * 0.75}rem` }}>
                    <a
                      href={`#${heading.slug}`}
                      class="toc-link text-zinc-500 dark:text-zinc-400 hover:text-zinc-950 dark:hover:text-zinc-50 hover:underline transition-colors block leading-snug focus-ring-custom rounded"
                      data-slug={heading.slug}
                    >
                      {heading.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </div>
        </aside>
      )}
      
    </div>
  </main>
</Layout>

<script>
  // Dynamic active TOC link highlighting using IntersectionObserver
  window.addEventListener('DOMContentLoaded', () => {
    const observerOptions = {
      root: null,
      rootMargin: '0px 0px -60% 0px',
      threshold: 0
    };

    const tocLinks = document.querySelectorAll('.toc-link');
    const headings = Array.from(tocLinks).map(link => {
      const slug = link.getAttribute('data-slug');
      return document.getElementById(slug || '');
    }).filter(Boolean);

    let activeLink: Element | null = null;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('id');
          const correspondingLink = document.querySelector(`.toc-link[data-slug="${id}"]`);
          
          if (correspondingLink) {
            if (activeLink) {
              activeLink.classList.remove('text-zinc-950', 'dark:text-zinc-50', 'font-semibold');
              activeLink.classList.add('text-zinc-500', 'dark:text-zinc-400');
            }
            correspondingLink.classList.remove('text-zinc-500', 'dark:text-zinc-400');
            correspondingLink.classList.add('text-zinc-950', 'dark:text-zinc-50', 'font-semibold');
            activeLink = correspondingLink;
          }
        }
      });
    }, observerOptions);

    headings.forEach(heading => {
      if (heading) observer.observe(heading);
    });
  });
</script>
