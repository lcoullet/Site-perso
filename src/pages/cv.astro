---
import Layout from "../layouts/Layout.astro";

// TODO: Remplacer cette URL par l'URL raw de ton fichier resume.json sur GitHub ou Gist
const RESUME_URL =
  "https://gist.github.com/lcoullet/6a444611f124bea3f5fe4f1cacb80b66/raw";

let resume;
try {
  const response = await fetch(RESUME_URL);
  resume = await response.json();
} catch (e) {
  console.error("Erreur lors de la récupération du JSON Resume", e);
  resume = null;
}

const { basics, work, education, skills, languages } = resume || {};
---

<Layout>
  <main id="main-content" class="container mx-auto px-6 py-12 max-w-4xl">
    {
      resume ? (
        <div class="bg-white shadow-xl rounded-2xl overflow-hidden animate-fade-in">
          {/* Header Section */}
          {basics && (
            <header class="bg-zinc-900 text-white p-10 sm:p-14">
              <h1 class="text-4xl sm:text-5xl font-bold tracking-tight mb-2">
                {basics.name}
              </h1>
              <p class="text-xl sm:text-2xl text-zinc-300 font-light mb-6">
                {basics.label}
              </p>

              <div class="flex flex-wrap gap-4 text-sm font-medium text-zinc-400">
                {basics.email && (
                  <a
                    href={`mailto:${basics.email}`}
                    class="flex items-center gap-1.5 hover:text-white transition-colors"
                  >
                    <svg
                      class="w-4 h-4"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                      />
                    </svg>
                    {basics.email}
                  </a>
                )}
                {basics.phone && (
                  <span class="flex items-center gap-1.5">
                    <svg
                      class="w-4 h-4"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                      />
                    </svg>
                    {basics.phone}
                  </span>
                )}
                {basics.location && (
                  <span class="flex items-center gap-1.5">
                    <svg
                      class="w-4 h-4"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                      />
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                      />
                    </svg>
                    {basics.location.city}
                    {basics.location.countryCode
                      ? `, ${basics.location.countryCode}`
                      : ""}
                  </span>
                )}
              </div>
            </header>
          )}

          <div class="p-10 sm:p-14 space-y-12">
            {/* Summary Section */}
            {basics?.summary && (
              <section>
                <h2 class="text-2xl font-bold text-zinc-900 mb-4 border-b border-zinc-200 pb-2">
                  Profil
                </h2>
                <p class="text-zinc-600 leading-relaxed max-w-3xl">
                  {basics.summary}
                </p>
              </section>
            )}

            {/* Experience Section */}
            {work && work.length > 0 && (
              <section>
                <h2 class="text-2xl font-bold text-zinc-900 mb-6 border-b border-zinc-200 pb-2">
                  Expérience
                </h2>
                <div class="space-y-8">
                  {work.map((job: any) => (
                    <div class="relative pl-6 border-l-2 border-zinc-200">
                      <div class="absolute w-3 h-3 bg-zinc-900 rounded-full -left-[7px] top-1.5 ring-4 ring-white" />
                      <div class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline mb-2">
                        <h3 class="text-lg font-bold text-zinc-900">
                          {job.position}
                        </h3>
                        <span class="text-sm font-medium text-zinc-600 bg-zinc-100 px-3 py-1 rounded-full w-fit mt-2 sm:mt-0">
                          {job.startDate} - {job.endDate || "Présent"}
                        </span>
                      </div>
                      {job.name && (
                        <p class="text-zinc-700 font-medium mb-3">
                          {job.url ? (
                            <a
                              href={job.url}
                              target="_blank"
                              rel="noopener noreferrer"
                              class="hover:underline text-blue-600"
                            >
                              {job.name}
                            </a>
                          ) : (
                            job.name
                          )}
                        </p>
                      )}
                      {job.summary && (
                        <p class="text-zinc-600 mb-3 text-sm leading-relaxed">
                          {job.summary}
                        </p>
                      )}
                      {job.highlights && job.highlights.length > 0 && (
                        <ul class="list-disc list-inside text-sm text-zinc-600 space-y-1 marker:text-zinc-400">
                          {job.highlights.map((highlight: any) => (
                            <li>{highlight}</li>
                          ))}
                        </ul>
                      )}
                    </div>
                  ))}
                </div>
              </section>
            )}

            {/* Education Section */}
            {education && education.length > 0 && (
              <section>
                <h2 class="text-2xl font-bold text-zinc-900 mb-6 border-b border-zinc-200 pb-2">
                  Formation
                </h2>
                <div class="space-y-6">
                  {education.map((edu: any) => (
                    <div class="bg-zinc-50 p-6 rounded-xl border border-zinc-100">
                      <div class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline mb-2">
                        <h3 class="text-lg font-bold text-zinc-900">
                          {edu.studyType} - {edu.area}
                        </h3>
                        <span class="text-sm font-medium text-zinc-600 whitespace-nowrap mt-2 sm:mt-0">
                          {edu.startDate} - {edu.endDate || "Présent"}
                        </span>
                      </div>
                      <p class="text-zinc-700 font-medium">{edu.institution}</p>
                      {edu.score && (
                        <p class="text-sm text-zinc-600 mt-1">
                          Score: {edu.score}
                        </p>
                      )}
                    </div>
                  ))}
                </div>
              </section>
            )}

            {/* Skills and Languages Grid */}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
              {skills && skills.length > 0 && (
                <section>
                  <h2 class="text-2xl font-bold text-zinc-900 mb-6 border-b border-zinc-200 pb-2">
                    Compétences
                  </h2>
                  <div class="flex flex-col gap-4">
                    {skills.map((skillGroup: any) => (
                      <div>
                        <h3 class="font-medium text-zinc-900 mb-2">
                          {skillGroup.name}
                        </h3>
                        <div class="flex flex-wrap gap-2">
                          {skillGroup.keywords &&
                            skillGroup.keywords.map((keyword: any) => (
                              <span class="px-3 py-1 bg-zinc-100 text-zinc-700 rounded-full text-sm hover:bg-zinc-200 transition-colors">
                                {keyword}
                              </span>
                            ))}
                        </div>
                      </div>
                    ))}
                  </div>
                </section>
              )}

              {languages && languages.length > 0 && (
                <section>
                  <h2 class="text-2xl font-bold text-zinc-900 mb-6 border-b border-zinc-200 pb-2">
                    Langues
                  </h2>
                  <ul class="space-y-3">
                    {languages.map((lang: any) => (
                      <li class="flex items-center justify-between p-3 bg-zinc-50 rounded-lg border border-zinc-100">
                        <span class="font-medium text-zinc-800">
                          {lang.language}
                        </span>
                        <span class="text-sm text-zinc-600 bg-white px-2 py-1 rounded shadow-sm">
                          {lang.fluency}
                        </span>
                      </li>
                    ))}
                  </ul>
                </section>
              )}
            </div>
          </div>
        </div>
      ) : (
        <div class="bg-red-50 text-red-700 p-6 rounded-lg border border-red-200 shadow-sm">
          <h2 class="text-xl font-bold mb-2 flex items-center gap-2">
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
              />
            </svg>
            Erreur de chargement
          </h2>
          <p>
            Impossible de générer le CV. Veuillez vérifier que l'URL du fichier
            `resume.json` est valide.
          </p>
        </div>
      )
    }
  </main>
</Layout>
