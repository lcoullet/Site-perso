---
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { title, description, pubDate, categories } = post.data;

// Format pubDate nicely in French
const formattedDate = new Date(pubDate).toLocaleDateString("fr-FR", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<article class="group relative flex flex-col gap-3 bg-white p-6 rounded-2xl border border-zinc-200/60 shadow-sm hover:shadow-md transition-all duration-300 hover:border-zinc-300/80">
  <div class="flex items-center gap-3 text-xs text-zinc-500">
    <time datetime={pubDate.toISOString()} class="font-medium">
      {formattedDate}
    </time>
    {categories.length > 0 && (
      <>
        <span class="text-zinc-300" aria-hidden="true">•</span>
        <div class="flex flex-wrap gap-1.5 relative z-10" aria-label="Catégories">
          {categories.map((category) => (
            <a
              href={`/blog/category/${encodeURIComponent(category)}`}
              class="px-2 py-0.5 rounded-full bg-zinc-100 hover:bg-zinc-200 text-zinc-600 hover:text-zinc-900 transition-colors font-medium"
            >
              {category}
            </a>
          ))}
        </div>
      </>
    )}
  </div>
  
  <h2 class="text-xl font-bold tracking-tight text-zinc-900 group-hover:text-zinc-700 transition-colors leading-snug">
    <a href={`/blog/${post.id}`} class="focus:outline-none">
      <!-- absolute overlay to make the whole card clickable EXCEPT the category links -->
      <span class="absolute inset-0 rounded-2xl" aria-hidden="true"></span>
      {title}
    </a>
  </h2>
  
  <p class="text-sm text-zinc-600 leading-relaxed line-clamp-3">
    {description}
  </p>

  <div class="mt-auto pt-2 flex items-center text-xs font-semibold text-zinc-950 group-hover:text-zinc-700 transition-colors gap-1">
    Lire la suite
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
    </svg>
  </div>
</article>
