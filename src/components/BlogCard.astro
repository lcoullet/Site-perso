---
import type { CollectionEntry } from "astro:content";
import { getReadingTime } from "../utils";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { title, description, pubDate, categories } = post.data;

// Format pubDate nicely in French
const formattedDate = new Date(pubDate).toLocaleDateString("fr-FR", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

// Calculate reading time
const readingTime = getReadingTime(post.body);
---

<article class="group relative flex flex-col gap-3 bg-white dark:bg-zinc-900 p-6 rounded-2xl border border-zinc-200/60 dark:border-zinc-800/60 shadow-sm hover:shadow-md transition-all duration-300 hover:border-zinc-300/80 dark:hover:border-zinc-700/80">
  <div class="flex flex-wrap items-center gap-2 sm:gap-3 text-xs text-zinc-500 dark:text-zinc-400">
    <time datetime={pubDate.toISOString()} class="font-medium">
      {formattedDate}
    </time>
    <span class="text-zinc-300 dark:text-zinc-700" aria-hidden="true">•</span>
    <span class="font-medium">{readingTime} min de lecture</span>
    {categories.length > 0 && (
      <>
        <span class="text-zinc-300 dark:text-zinc-700" aria-hidden="true">•</span>
        <div class="flex flex-wrap gap-1.5 relative z-10" aria-label="Catégories">
          {categories.map((category) => (
            <a
              href={`/blog/category/${encodeURIComponent(category)}`}
              class="px-2 py-0.5 rounded-full bg-zinc-100 dark:bg-zinc-800 hover:bg-zinc-200 dark:hover:bg-zinc-700 text-zinc-600 dark:text-zinc-300 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors font-medium focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-zinc-950 dark:focus-visible:ring-zinc-50 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-zinc-900"
            >
              {category}
            </a>
          ))}
        </div>
      </>
    )}
  </div>
  
  <h2 class="text-xl font-bold tracking-tight text-zinc-900 dark:text-zinc-50 group-hover:text-zinc-700 dark:group-hover:text-zinc-300 transition-colors leading-snug">
    <a href={`/blog/${post.id}`} class="main-link focus:outline-none">
      <!-- absolute overlay to make the whole card clickable EXCEPT the category links -->
      <span class="card-overlay absolute inset-0 rounded-2xl" aria-hidden="true"></span>
      {title}
    </a>
  </h2>
  
  <p class="text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed line-clamp-3">
    {description}
  </p>

  <div class="mt-auto pt-2 flex items-center text-xs font-semibold text-zinc-950 dark:text-zinc-50 group-hover:text-zinc-700 dark:group-hover:text-zinc-300 transition-colors gap-1">
    Lire la suite
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
    </svg>
  </div>
</article>

<style>
  /* Beautiful custom focus ring around the whole card when the main link is focused via keyboard */
  .main-link:focus-visible .card-overlay {
    box-shadow: 0 0 0 2px #fff, 0 0 0 4px #09090b;
  }
  :global(.dark) .main-link:focus-visible .card-overlay {
    box-shadow: 0 0 0 2px #09090b, 0 0 0 4px #f4f4f5;
  }
</style>
