---
import "../styles/global.css";
import Footer from "../components/Footer.astro";
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link
			href="https://fonts.googleapis.com/css2?family=Rubik:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&display=swap"
			rel="stylesheet"
		/>
		<meta name="generator" content={Astro.generator} />
		<title>Ludovic Coullet</title>
	</head>
	<body class="bg-zinc-50 text-zinc-900 antialiased min-h-screen flex flex-col">
		<a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-0 focus:left-0 focus:z-50 focus:p-4 focus:bg-white focus:text-zinc-900">Aller au contenu principal</a>
		
		<header class="sticky top-0 z-40 w-full backdrop-blur-md bg-white/70 border-b border-zinc-200/50">
			<div class="container mx-auto px-6 h-16 flex items-center justify-between">
				<a class="text-lg font-medium tracking-tight hover:text-zinc-600 transition-colors" href="/" aria-label="Accueil">Ludovic Coullet</a>
				<nav aria-label="Navigation Principale">
					<ul class="flex items-center gap-2 sm:gap-4 text-sm font-medium text-zinc-600">
						<li>
							<a href="/" class="px-3 py-2 rounded-lg hover:bg-zinc-100 hover:text-zinc-900 transition-all duration-200" aria-current="page">Accueil</a>
						</li>
						<li>
							<a href="/cv" class="px-3 py-2 rounded-lg hover:bg-zinc-100 hover:text-zinc-900 transition-all duration-200">CV</a>
						</li>
					</ul>
				</nav>
			</div>
		</header>
		<slot />
		<Footer />
	</body>
</html>
