---
import "../styles/global.css";
import Footer from "../components/Footer.astro";

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "Ludovic Coullet", 
	description = "Site personnel et blog de Ludovic Coullet" 
} = Astro.props;

const { pathname } = Astro.url;

// Helper to determine if a path is active
const isActive = (path: string) => {
	if (path === "/") {
		return pathname === "/" || pathname === "";
	}
	return pathname.startsWith(path);
};

const navItems = [
	{ href: "/", label: "Accueil" },
	{ href: "/blog", label: "Blog" },
	{ href: "/cv", label: "CV" },
	{ href: "/soundcloud", label: "Musique" },
];
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link
			href="https://fonts.googleapis.com/css2?family=Rubik:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&display=swap"
			rel="stylesheet"
		/>
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body class="bg-zinc-50 text-zinc-900 antialiased min-h-screen flex flex-col">
		<a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-0 focus:left-0 focus:z-50 focus:p-4 focus:bg-white focus:text-zinc-900">Aller au contenu principal</a>
		
		<header class="sticky top-0 z-40 w-full backdrop-blur-md bg-white/70 border-b border-zinc-200/50">
			<div class="container mx-auto px-6 h-16 flex items-center justify-between">
				<a class="text-lg font-semibold tracking-tight hover:text-zinc-600 transition-colors" href="/">Ludovic Coullet</a>
				<nav aria-label="Navigation Principale">
					<ul class="flex items-center gap-1 sm:gap-2 text-sm font-medium">
						{navItems.map((item) => {
							const active = isActive(item.href);
							return (
								<li>
									<a
										href={item.href}
										class={`px-3 py-2 rounded-lg transition-all duration-200 ${
											active
												? "bg-zinc-100 text-zinc-900 font-semibold"
												: "text-zinc-600 hover:bg-zinc-100 hover:text-zinc-900"
										}`}
										aria-current={active ? "page" : undefined}
									>
										{item.label}
									</a>
								</li>
							);
						})}
					</ul>
				</nav>
			</div>
		</header>
		<slot />
		<Footer />
	</body>
</html>
